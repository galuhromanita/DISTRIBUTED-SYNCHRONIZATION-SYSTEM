NODE_ID=node-1
NODE_HOST=localhost
NODE_PORT=5000
CLUSTER_NAME=distributed-cluster

REDIS_HOST=localhost
REDIS_PORT=6379

LOG_LEVEL=INFO

# Raft configuration
RAFT_ELECTION_TIMEOUT_MIN=1.5
RAFT_ELECTION_TIMEOUT_MAX=3.0
RAFT_HEARTBEAT_INTERVAL=0.5

# Queue configuration
QUEUE_NUM_PARTITIONS=10
QUEUE_REPLICATION_FACTOR=3

# Cache configuration
CACHE_PROTOCOL=MESI
CACHE_REPLACEMENT_POLICY=LRU
CACHE_MAX_SIZE=10000
